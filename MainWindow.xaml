<Window x:Class="CascadeLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CascadeLauncher.ViewModels"
        Title="Cascade Launcher"
        Width="780" Height="480"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{StaticResource UiFont}"
        Foreground="{StaticResource TextBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- Outer rounded shell so we get rounded corners + shadow -->
    <Border x:Name="Shell"
            CornerRadius="16"
            Background="{StaticResource WindowBackdropBrush}"
            Margin="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.55" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- title bar -->
                <RowDefinition Height="*"/>     <!-- body -->
                <RowDefinition Height="Auto"/>  <!-- footer -->
            </Grid.RowDefinitions>

            <!-- Title bar (drag area + chrome) -->
            <Grid Grid.Row="0" Height="42" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0,0,0">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Cascade Launcher"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Alpha"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               Margin="8,1,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ChromeButton}" Content="&#xE921;" Click="Min_Click" ToolTip="Minimize"/>
                    <Button Style="{StaticResource ChromeButton}" Content="&#xE8BB;" Click="Close_Click" ToolTip="Close"/>
                </StackPanel>
            </Grid>

            <!-- Body: hero + status are now grouped together, centred. -->
            <Grid Grid.Row="1" Margin="40,12,40,12">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MinWidth="420">
                    <TextBlock Text="Cascade Client"
                               FontSize="38"
                               FontWeight="Light"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Warm. Cozy. Fast."
                               FontSize="14"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,28"/>

                    <Button Style="{StaticResource LaunchButton}"
                            Content="{Binding LaunchButtonText}"
                            IsEnabled="{Binding CanLaunch}"
                            Click="Launch_Click"
                            MinWidth="220"
                            HorizontalAlignment="Center"/>

                    <!-- Status row sits directly under the button so progress is read top-down. -->
                    <ProgressBar Style="{StaticResource WoodyProgressBar}"
                                 Minimum="0" Maximum="1"
                                 Value="{Binding Progress, Mode=OneWay}"
                                 IsIndeterminate="{Binding IsIndeterminate, Mode=OneWay}"
                                 Visibility="{Binding ProgressVisibility}"
                                 Margin="0,16,0,0"
                                 HorizontalAlignment="Stretch"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12"
                               Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>

            <!--
                Footer: rounded bottom corners + EULA-required non-affiliation
                disclaimer. Mojang's Brand & Asset Usage Guidelines require
                third-party launchers to clearly state that they are not
                approved by or associated with Mojang/Microsoft.
            -->
            <Border Grid.Row="2"
                    Background="{StaticResource DividerBrush}"
                    CornerRadius="0,0,16,16"
                    Padding="22,10">
                <TextBlock Foreground="{StaticResource TextMutedBrush}"
                           FontSize="10"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    Not affiliated with, approved by, or endorsed by Mojang Studios or Microsoft.
                    Minecraft is a trademark of Mojang Studios.
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>
